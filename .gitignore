# Per-site .gitignore — this folder is its own independent git repo.

# Dependencies
node_modules/

# Build output
dist/

# Astro generated types/cache
.astro/

# Cloudflare / Wrangler
.wrangler/

# Env / secrets (form keys, SITE_URL overrides, etc.)
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
