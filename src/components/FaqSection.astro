---
/**
 * FaqSection.astro — accessible accordion via native <details>. FAQ schema is
 * emitted separately by the page (faqPage()); this just renders the visible Q&A.
 */
import type { Faq } from '@config/services';

interface Props {
  faqs: Faq[];
  title?: string;
}
const { faqs, title = 'Frequently Asked Questions' } = Astro.props;
---

{
  faqs.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <h2>{title}</h2>
        </div>
        <div class="faq-list prose">
          {faqs.map((f) => (
            <details class="faq">
              <summary>{f.q}</summary>
              <div class="faq-body">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .faq-list {
    max-width: 820px;
  }
</style>
