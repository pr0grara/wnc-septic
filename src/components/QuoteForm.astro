---
/**
 * QuoteForm.astro — primary lead-capture form.
 * Backend is chosen in site.ts:
 *   - Web3Forms: formEndpoint = api.web3forms.com/submit + formAccessKey
 *   - Formspree:  formEndpoint = formspree.io/f/xxxx (no key)
 *   - Worker/custom: any endpoint accepting multipart/form-data POST → 2xx
 *   - Call-only:  formEndpoint = "" → submit disabled, shows "call us instead"
 */
import { SITE, tel } from '@config/site';

interface Props {
  source?: string;
  heading?: string;
  sub?: string;
}
const {
  source = 'website',
  heading = 'Request a Free Quote',
  sub = 'Tell us where your tank is and what’s going on — we’ll call you back with a quote.',
} = Astro.props;

const subject = `New lead — ${SITE.company} (${source})`;

// Web3Forms requires an access key; without one the POST would fail, so fall back to
// call-only mode. Non-Web3Forms endpoints (e.g. a Worker) don't need a key.
const usesWeb3Forms = SITE.formEndpoint.includes('web3forms.com');
const activeEndpoint =
  SITE.formEndpoint && (!usesWeb3Forms || SITE.formAccessKey) ? SITE.formEndpoint : '';
---

<div class="card quote-form" id="quote">
  <h3>{heading}</h3>
  <p class="muted">{sub}</p>

  <form id="lead-form" novalidate data-endpoint={activeEndpoint} data-phone={SITE.phoneDisplay}>
    {SITE.formAccessKey ? <input type="hidden" name="access_key" value={SITE.formAccessKey} /> : null}
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="subject" value={subject} />
    <input type="hidden" name="from_name" value={SITE.company} />

    <!-- honeypot: real people leave this empty -->
    <div class="hp" aria-hidden="true">
      <label>Company Website<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
    </div>

    <div class="field">
      <label for="lf-name">Name <span class="req">*</span></label>
      <input id="lf-name" name="name" type="text" autocomplete="name" required />
    </div>
    <div class="field">
      <label for="lf-phone">Phone</label>
      <input id="lf-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" />
    </div>
    <div class="field">
      <label for="lf-email">Email <span class="req">*</span></label>
      <input id="lf-email" name="email" type="email" autocomplete="email" required />
    </div>
    <div class="field">
      <label for="lf-address">Property address or area</label>
      <input id="lf-address" name="address" type="text" placeholder="e.g. Leicester, or a street near Asheville" />
    </div>
    <div class="field">
      <label for="lf-message">What’s going on with your septic?</label>
      <textarea id="lf-message" name="message" rows="4" placeholder="Routine pump, backup, soggy yard, alarm, or an inspection for a home sale… and when it was last pumped if you know."></textarea>
    </div>
    <div class="field">
      <label for="lf-photo">Photo (optional)</label>
      <input id="lf-photo" name="photo" type="file" accept="image/*" />
    </div>

    <p class="consent-note muted">
      By submitting, you agree that {SITE.company} may contact you by phone or email about your
      request. See our <a href="/privacy">Privacy Policy</a>.
    </p>

    <button type="submit" class="btn btn-primary btn-lg btn-block" id="lf-submit">
      Send My Request
    </button>
    <p class="form-status" id="form-status" role="status" aria-live="polite"></p>

    <p class="muted or-call">
      Prefer to talk now? Call <a href={tel()}>{SITE.phoneDisplay}</a>.
    </p>
  </form>
</div>

<style>
  .quote-form h3 {
    margin-bottom: 4px;
  }
  .or-call {
    margin: 14px 0 0;
    text-align: center;
  }
  .consent-note {
    font-size: 0.78rem;
    line-height: 1.45;
    margin: 4px 0 14px;
  }
</style>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  if (form && statusEl) {
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const field = (name: string) => form.elements.namedItem(name) as HTMLInputElement | null;

    const setStatus = (msg: string, kind?: 'ok' | 'err') => {
      statusEl.textContent = msg;
      statusEl.className = 'form-status' + (kind ? ' ' + kind : '');
    };

    const endpoint = form.getAttribute('data-endpoint') || '';
    const phone = form.getAttribute('data-phone') || '';
    const submitBtn = document.getElementById('lf-submit') as HTMLButtonElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // honeypot — bots fill this; bail silently as if successful
      const hp = field('company_website');
      if (hp && hp.value.trim() !== '') {
        setStatus('Thanks — we’ll be in touch shortly.', 'ok');
        form.reset();
        return;
      }

      const nameEl = field('name');
      const emailEl = field('email');
      if (!nameEl || !nameEl.value.trim()) {
        setStatus('Please enter your name.', 'err');
        nameEl?.focus();
        return;
      }
      if (!emailEl || !emailRe.test(emailEl.value.trim())) {
        setStatus('Please enter a valid email address.', 'err');
        emailEl?.focus();
        return;
      }

      // Call-only fallback: no endpoint configured → acknowledge without sending.
      if (!endpoint) {
        setStatus('Thanks — we got your request and will call you back shortly.', 'ok');
        form.reset();
        return;
      }

      setStatus('Sending…');
      if (submitBtn) submitBtn.disabled = true;
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          setStatus('Thanks — we got your request and will call you back shortly.', 'ok');
          form.reset();
        } else {
          setStatus(
            phone ? `Something went wrong. Please call us at ${phone}.` : 'Something went wrong — please try again or call us.',
            'err',
          );
        }
      } catch {
        setStatus(
          phone ? `Couldn’t send right now. Please call us at ${phone}.` : 'Couldn’t send right now — please try again or call us.',
          'err',
        );
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
