---
/**
 * ServiceAreaMap.astro — keyless Google Maps embeds for the counties we cover,
 * plus a quick city list. Update COUNTIES for a new region (names + Google query).
 * Keyless embed: https://www.google.com/maps?q=<query>&output=embed (no API key).
 */
import { SITE } from '@config/site';
import { CITIES } from '@config/cities';
import { cityUrl } from '../lib/urls';

interface County {
  name: string;
  query: string;
}

// Western NC mountain coverage (Buncombe County + the surrounding mountain counties).
const COUNTIES: County[] = [
  { name: 'Asheville & Buncombe County', query: 'Asheville, North Carolina' },
  { name: 'Hendersonville, Haywood & the Surrounding Mountains', query: 'Hendersonville, North Carolina' },
];

const embed = (q: string) =>
  `https://www.google.com/maps?q=${encodeURIComponent(q)}&output=embed`;
---

<section class="section section-soft" id="service-area">
  <div class="container">
    <div class="section-head">
      <h2>Septic Service Across {SITE.region}</h2>
      <p class="lead muted">
        {SITE.company} covers {SITE.region} and the surrounding mountain counties — we come to your
        property, in town or up a cove. Don’t see your area? Call us — we likely cover it.
      </p>
    </div>

    <div class="map-grid">
      {
        COUNTIES.map((c) => (
          <div class="map-card card">
            <h3>{c.name}</h3>
            <div class="map-frame">
              <iframe
                title={`Map of ${c.name}`}
                src={embed(c.query)}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              />
            </div>
          </div>
        ))
      }
    </div>

    <ul class="cities area-cities">
      {
        CITIES.map((c) => (
          <li>
            <a href={cityUrl(c)}>{c.name}{c.state ? `, ${c.state}` : ''}</a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .map-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-bottom: 26px;
  }
  .map-card h3 {
    margin-bottom: 14px;
  }
  .map-frame {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line);
  }
  .map-frame iframe {
    width: 100%;
    height: 280px;
    border: 0;
    display: block;
  }
  .area-cities {
    margin-top: 6px;
  }
  @media (max-width: 920px) {
    .map-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
